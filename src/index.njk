<section class="cv-section" id="education">
  <h2 class="label">Education</h2>
  {% for item in cv.education %}
  <div class="entry">
    <div class="entry-period">{{ item.period }}</div>
    <div class="entry-body">
      <p class="entry-title">{{ item.title }}</p>
      {% if item.where %}<p class="entry-where">{{ item.where }}</p>{% endif %}
      {% if item.detail %}<p class="entry-detail">{{ item.detail }}</p>{% endif %}
    </div>
  </div>
  {% endfor %}
</section>

<section class="cv-section" id="experience">
  <h2 class="label">Experience</h2>
  {% for item in cv.experience %}
  <div class="entry">
    <div class="entry-period">{{ item.period }}</div>
    <div class="entry-body">
      <p class="entry-title">{{ item.title }}</p>
      {% if item.where %}<p class="entry-where">{{ item.where }}</p>{% endif %}
      {% if item.detail %}<p class="entry-detail">{{ item.detail }}</p>{% endif %}
    </div>
  </div>
  {% endfor %}
</section>

<section class="cv-section" id="publications">
  <h2 class="label">Selected Publications</h2>
  {% for pub in cv.publications %}
  <div class="entry">
    <div class="entry-period">{{ pub.date }}</div>
    <div class="entry-body">
      <p class="entry-title">{{ pub.title }}</p>
      <p class="entry-where">{{ pub.venue }}{% if pub.note %} &middot; {{ pub.note }}{% endif %}</p>
      <p class="entry-detail">{{ pub.authors | replace("Seungmin Kim", "<strong>Seungmin Kim</strong>") | safe }}</p>
    </div>
  </div>
  {% endfor %}
</section>

<section class="cv-section" id="projects">
  <h2 class="label">Research Projects</h2>
  {% for item in cv.projects %}
  <div class="entry">
    <div class="entry-period">{{ item.period }}</div>
    <div class="entry-body">
      <p class="entry-title">{{ item.title }}</p>
      {% if item.where %}<p class="entry-where">{{ item.where }}</p>{% endif %}
      {% if item.detail %}<p class="entry-detail">{{ item.detail }}</p>{% endif %}
    </div>
  </div>
  {% endfor %}
</section>

<p class="cv-more"><a href="{{ site.author.cvPath }}" target="_blank" rel="noopener">Full CV (PDF) &rarr;</a></p>
